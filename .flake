[flake8]
# Исключаемые директории
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    migrations,
    .pytest_cache,
    .mypy_cache
    ./venv/*,
    ./.venv/*,
    ./__pycache__/*,
    ./.git/*,
    ./migrations/*,
    ./.pytest_cache/*,
    ./.mypy_cache/*

# Максимальная длина строки (как в Black)
max-line-length = 88

# Игнорируемые ошибки
# E203: пробелы до двоеточия (несовместимо с Black)
# W503: разрыв строки перед бинарным оператором (несовместимо с Black)
extend-ignore = E203, W503

# Сложность функций (максимум 10)
max-complexity = 10

# Допустимые имена для переменных (игнорировать предупреждения)
per-file-ignores = __init__.py:F401